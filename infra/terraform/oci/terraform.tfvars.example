# OCI Terraform configuration example
region         = "ap-kulai-2"
compartment_id = "ocid1.compartment.oc1..example"
execution_mode = "parallel" # "parallel" or "sequential"
node_shape     = "VM.Standard.E5.Flex" # Fallback: "VM.Standard.E4.Flex"
# db_password    = "YourSecurePassword123!" # Pass via TF_VAR_db_password or set in local tfvars

# Node shape configurations
app_node_ocpus           = 8  # 8 OCPU = 16 vCPUs
app_node_memory_in_gbs   = 32
app_node_count           = 1

testing_node_ocpus       = 1  # 1 OCPU = 2 vCPUs
testing_node_memory_in_gbs = 4
testing_node_count       = 1

# OKE Kubernetes Version
kubernetes_version = "v1.30.1"

# OCI CLI / API Credentials (optional if using default ~/.oci/config profile)
# tenancy_ocid     = "ocid1.tenancy.oc1..example"
# user_ocid        = "ocid1.user.oc1..example"
# fingerprint      = "aa:bb:cc:dd:ee:ff:11:22:33:44:55:66:77:88:99:00"
# private_key_path = "~/.oci/oci_api_key.pem"
