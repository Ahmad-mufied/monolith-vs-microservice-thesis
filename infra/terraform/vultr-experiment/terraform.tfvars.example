project               = "skripsi"
region                = "sgp"
kubernetes_version    = "v1.33.0+1"
monolith_cluster_name = "skripsi-vultr-monolith"
msa_cluster_name      = "skripsi-vultr-msa"

# Cost-impacting benchmark SKUs. The parallel stack intentionally creates both
# monolith and MSA clusters, so these plans are charged twice until destroyed.
# Use vultr-experiment-sequential when quota or budget cannot support both.
app_node_plan         = "voc-c-16c-32gb-300s"
testing_node_plan     = "vc2-4c-8gb"
postgres_plan         = "vc2-4c-8gb"
postgres_os_id        = 1743

# Do not put postgres_password in tfvars. Set POSTGRES_PASSWORD in env/vultr.env;
# scripts/terraform-vultr.sh exports it as TF_VAR_postgres_password at runtime.
