project                 = "skripsi"
region                  = "sgp"
kubernetes_version      = "v1.33.0+1"
sequential_cluster_name = "skripsi-vultr-benchmark"
app_node_plan           = "voc-c-16c-32gb-300s"
testing_node_plan       = "vc2-4c-8gb"
postgres_plan           = "vc2-4c-8gb"
postgres_os_id          = 1743

# Do not put postgres_password in tfvars. Set POSTGRES_PASSWORD in env/vultr.env;
# scripts/terraform-vultr.sh exports it as TF_VAR_postgres_password at runtime.
