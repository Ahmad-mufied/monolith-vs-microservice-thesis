aws_region          = "ap-southeast-1"
project             = "skripsi"
monolith_cluster_name = "skripsi-monolith"
msa_cluster_name      = "skripsi-msa"
cluster_endpoint_public_access_cidrs = ["REPLACE_WITH_OPERATOR_PUBLIC_IP_CIDR"]
# db_password is injected at runtime via TF_VAR_db_password
db_instance_class   = "db.t3.micro"
