# Oracle Cloud Infrastructure (OCI) Benchmark Environment Settings
CLOUD_PROVIDER=oci
OCI_REGION=ap-kulai-2
OCI_COMPARTMENT_OCID=ocid1.compartment.oc1..example
OCI_EXECUTION_MODE=parallel

# Image Registry Settings (OCIR or Docker Hub)
# For OCIR: <region>.ocir.io/<tenancy-namespace>/<image>
OCIR_NAMESPACE=
# For Docker Hub fallback:
DOCKERHUB_NAMESPACE=ahmadmufied

# Cluster Names
OCI_MONOLITH_CLUSTER_NAME=skripsi-oci-monolith
OCI_MSA_CLUSTER_NAME=skripsi-oci-msa
OCI_SEQUENTIAL_CLUSTER_NAME=skripsi-oci-sequential

# Database Settings
POSTGRES_USER=postgres_admin
POSTGRES_PASSWORD=ChangeMe123!SecurePassword
