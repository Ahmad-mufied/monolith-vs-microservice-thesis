# =========================
# Go
# =========================
bin/
build/
dist/
tmp/
**/tmp/
*.test
*.out
coverage.out
coverage.html
*.coverprofile

# Go workspace local checksum file.
# Keep ignored if each module commits go.sum separately.
go.work.sum

# =========================
# Go Generated / Tooling
# =========================
*.pb.go
*_grpc.pb.go

# Keep generated proto output ignored by default.
# Remove this rule if generated code will be committed.
proto/gen/

# Auth PR needs generated auth stubs and proto/gen module metadata committed.
!proto/gen/
proto/gen/*
!proto/gen/go.mod
!proto/gen/go.sum
!proto/gen/auth/
proto/gen/auth/*
!proto/gen/auth/v1/
!proto/gen/auth/v1/*.pb.go
!proto/gen/item/
proto/gen/item/*
!proto/gen/item/v1/
!proto/gen/item/v1/*.pb.go
!proto/gen/transaction/
proto/gen/transaction/*
!proto/gen/transaction/v1/
!proto/gen/transaction/v1/*.pb.go

