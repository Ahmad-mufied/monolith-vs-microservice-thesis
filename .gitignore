# =========================
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/
*.iml

# =========================
# Environment / Secrets
# =========================
.env
.env.*
!.env.example
*.env
env/values.yaml
env/*resource-baseline.json
*.local
*.secret
*.secrets
secrets/
.secret/
*.pem
*.key
*.crt
*.p12
*.pfx
